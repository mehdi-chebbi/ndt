# AI Configuration
# ===================
# Choose one of the two configurations below:

# OPTION 1: Local AI Model (e.g., llama.cpp, Ollama, vLLM)
# ---------------------------------------------------------
AI_BASE_URL=http://192.168.2.97:8080/v1
AI_MODEL=qwen35
AI_API_KEY=dummy-key
# Don't set AI_APP_URL for local models (it's OpenRouter-specific)
# AI_APP_URL=
# AI_APP_NAME=

# OPTION 2: OpenRouter (or any OpenAI-compatible API)
# ---------------------------------------------------
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL=openai/gpt-4o
# AI_API_KEY=sk-or-v1-your-key-here
# AI_APP_URL=http://localhost:3000
# AI_APP_NAME=NDT Platform

# Other OpenRouter model examples:
# AI_MODEL=anthropic/claude-3.5-sonnet
# AI_MODEL=google/gemini-pro-1.5
# AI_MODEL=meta-llama/llama-3.1-70b-instruct
